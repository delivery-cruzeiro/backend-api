// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// MODELO USER (Usuários)
// ============================================

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  emailVerified DateTime?
  password      String?
  name          String
  phone         String?
  avatar        String?
  role          UserRole       @default(CLIENT)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  addresses     Address[]
  paymentMethods PaymentMethod[]
  orders        Order[]
  notifications Notification[]
  points        Point[]
  reviews       Review[]
  favorites     Favorite[]
  
  // Better Auth fields
  accounts      Account[]
  sessions      Session[]
  
  @@index([email])
  @@index([role])
}

// ============================================
// MODELO ACCOUNT (Better Auth)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================
// MODELO SESSION (Better Auth)
// ============================================

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserRole {
  CLIENT
  ADMIN
  MANAGER
  SUPER_ADMIN
}

// ============================================
// MODELO ADDRESS (Endereços)
// ============================================

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  street      String
  number      String
  complement  String?
  neighborhood String
  city        String
  state       String
  zipCode     String
  latitude    Float?
  longitude   Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  orders      Order[]
  
  @@index([userId])
}

// ============================================
// MODELO PAYMENT_METHOD (Métodos de Pagamento)
// ============================================

model PaymentMethod {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          PaymentType
  provider      String   // AbacatePay, Stripe, etc.
  providerId    String   // ID do método no provider
  last4         String?  // Últimos 4 dígitos do cartão
  expiryMonth   Int?
  expiryYear    Int?
  cardHolder    String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  payments      Payment[]
  orders        Order[]
  
  @@index([userId])
}

enum PaymentType {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CASH
}

// ============================================
// MODELO CATEGORY (Categorias de Produtos)
// ============================================

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  imageUrl    String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  products    Product[]
  
  @@index([isActive])
}

// ============================================
// MODELO PRODUCT (Produtos)
// ============================================

model Product {
  id          String   @id @default(cuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  orderItems  OrderItem[]
  promotions  PromotionProduct[]
  reviews     Review[]
  favorites   Favorite[]
  
  @@index([categoryId])
  @@index([isActive])
}

// ============================================
// MODELO ORDER (Pedidos)
// ============================================

model Order {
  id                String      @id @default(cuid())
  userId            String?
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  addressId         String
  address           Address     @relation(fields: [addressId], references: [id])
  paymentMethodId   String?
  paymentMethod     PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  status            OrderStatus @default(PENDING)
  subtotal          Decimal     @db.Decimal(10, 2)
  deliveryFee       Decimal     @db.Decimal(10, 2)
  discount          Decimal     @default(0) @db.Decimal(10, 2)
  total             Decimal     @db.Decimal(10, 2)
  notes             String?
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  items             OrderItem[]
  payments          Payment[]
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING        // Pedido feito, aguardando aprovação
  CONFIRMED      // Pedido confirmado
  PREPARING      // Em preparação
  ON_THE_WAY     // A caminho
  DELIVERED      // Entregue
  CANCELLED      // Cancelado
}

// ============================================
// MODELO ORDER_ITEM (Itens do Pedido)
// ============================================

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  notes     String?
  
  @@index([orderId])
  @@index([productId])
}

// ============================================
// MODELO PAYMENT (Pagamentos)
// ============================================

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  provider        String        // AbacatePay
  providerTxId    String?       // ID da transação no provider
  providerResponse Json?        // Resposta completa do provider
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([orderId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================
// MODELO PROMOTION (Promoções)
// ============================================

model Promotion {
  id          String           @id @default(cuid())
  name        String
  description String?
  type        PromotionType
  value       Decimal          @db.Decimal(10, 2)
  minPurchase Decimal?         @db.Decimal(10, 2)
  maxDiscount Decimal?         @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  products    PromotionProduct[]
  
  @@index([isActive])
  @@index([startDate, endDate])
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_X_GET_Y
}

model PromotionProduct {
  id           String    @id @default(cuid())
  promotionId  String
  promotion    Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([promotionId, productId])
}

// ============================================
// MODELO SYSTEM_SETTINGS (Configurações do Sistema)
// ============================================

model SystemSettings {
  id                String   @id @default(cuid())
  storeName         String   @default("Delivery Cruzeiro")
  storeOpen         Boolean  @default(true)
  autoApproveOrders Boolean  @default(false)
  minOrderValue     Decimal  @default(0) @db.Decimal(10, 2)
  freeDeliveryMin   Decimal?  @db.Decimal(10, 2)
  pointsEnabled     Boolean  @default(false)
  pointsPerReal     Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// MODELO DELIVERY_ZONE (Zonas de Entrega)
// ============================================

model DeliveryZone {
  id          String   @id @default(cuid())
  name        String
  neighborhood String
  city        String
  state       String
  zipCode     String?
  fee         Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive])
}

// ============================================
// MODELO NOTIFICATION (Notificações)
// ============================================

model Notification {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean            @default(false)
  createdAt DateTime           @default(now())
  
  @@index([userId])
  @@index([isRead])
}

enum NotificationType {
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_ON_THE_WAY
  ORDER_DELIVERED
  ORDER_CANCELLED
  PROMOTION
  SYSTEM
}

// ============================================
// MODELO POINT (Pontos de Fidelidade)
// ============================================

model Point {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     String?
  amount      Int         // Pontos ganhos ou gastos
  type        PointType
  description String?
  createdAt   DateTime    @default(now())
  
  @@index([userId])
}

enum PointType {
  EARNED
  REDEEMED
}

// ============================================
// MODELO REVIEW (Avaliações)
// ============================================

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  comment   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, productId])
  @@index([productId])
}

// ============================================
// MODELO FAVORITE (Favoritos)
// ============================================

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}
