# Database
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Server
PORT=4000
NODE_ENV=production

# JWT
JWT_SECRET=your-super-secure-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Better Auth
BETTER_AUTH_SECRET=your-super-secure-better-auth-secret-change-in-production
BETTER_AUTH_URL=https://api.deliverycruzeiro.com

# AbacatePay
ABACATEPAY_API_KEY=your-production-abacatepay-api-key
ABACATEPAY_API_URL=https://api.abacatepay.com.br

# Cloudinary
CLOUDINARY_URL=cloudinary://api-key:api-secret@cloud-name
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_FOLDER=delivery-cruzeiro

# Email (SMTP)
SMTP_HOST=smtp.production-provider.com
SMTP_PORT=587
SMTP_USER=your-production-email@example.com
SMTP_PASS=your-production-smtp-password
SMTP_FROM=noreply@deliverycruzeiro.com

# WhatsApp
WHATSAPP_API_URL=https://api.whatsapp-service.com
WHATSAPP_API_KEY=your-production-whatsapp-api-key
WHATSAPP_PHONE_NUMBER=5511999999999

# CORS
FRONTEND_URL=https://deliverycruzeiro.com

# Fiscal / SEFAZ
CERTIFICATE_PATH=
CERTIFICATE_PASSWORD=
SEFAZ_ENVIRONMENT=1
SEFAZ_AUTHORIZATION_URL=
SEFAZ_NFE_AUTHORIZATION_URL=
SEFAZ_NFCE_AUTHORIZATION_URL=
SEFAZ_AUTHORIZATION_URL_HOMOLOG=
CSC_ID=
CSC_PRODUCTION=
CSC_HOMOLOGATION=
NFCE_QRCODE_URL_PRODUCTION=https://www.sefaz.pb.gov.br/nfce/qrcode
NFCE_QRCODE_URL_HOMOLOGATION=https://www.sefaz.pb.gov.br/nfce/qrcode-homolog
