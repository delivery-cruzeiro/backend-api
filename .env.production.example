# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password-change-in-production
POSTGRES_DB=delivery_cruzeiro
POSTGRES_PORT=5432

# Server
PORT=4000
NODE_ENV=production

# JWT
JWT_SECRET=your-super-secure-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Better Auth
BETTER_AUTH_SECRET=your-super-secure-better-auth-secret-change-in-production
BETTER_AUTH_URL=https://api.deliverycruzeiro.com

# AbacatePay
ABACATEPAY_API_KEY=your-production-abacatepay-api-key
ABACATEPAY_API_URL=https://api.abacatepay.com.br

# Email (SMTP)
SMTP_HOST=smtp.production-provider.com
SMTP_PORT=587
SMTP_USER=your-production-email@example.com
SMTP_PASS=your-production-smtp-password
SMTP_FROM=noreply@deliverycruzeiro.com

# WhatsApp
WHATSAPP_API_URL=https://api.whatsapp-service.com
WHATSAPP_API_KEY=your-production-whatsapp-api-key
WHATSAPP_PHONE_NUMBER=5511999999999

# CORS
FRONTEND_URL=https://deliverycruzeiro.com
